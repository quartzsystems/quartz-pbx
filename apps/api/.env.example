# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:password@localhost:5432/quartz_pbx"

# Asterisk ARI settings
ASTERISK_HOST=localhost
ASTERISK_ARI_PORT=8088
ASTERISK_ARI_USER=asterisk
ASTERISK_ARI_PASSWORD=asterisk
ASTERISK_ARI_APP=quartz-pbx

# Path where Asterisk reads the generated PJSIP config
# Include this file in /etc/asterisk/pjsip.conf via: #include pjsip_quartz.conf
ASTERISK_CONFIG_PATH=/etc/asterisk/pjsip_quartz.conf

# API server
PORT=4000
HOST=0.0.0.0

# Allowed CORS origin (frontend URL)
WEB_URL=http://localhost:3000
